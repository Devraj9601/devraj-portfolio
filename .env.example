# EmailJS Configuration
# Get these values from https://www.emailjs.com/

# Your EmailJS Public Key (available in EmailJS Account Settings)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (from EmailJS Email Services)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (from EmailJS Email Templates)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Your EmailJS Reply Template ID (optional, for auto-reply to sender)
VITE_EMAILJS_REPLY_TEMPLATE_ID=your_reply_template_id_here
